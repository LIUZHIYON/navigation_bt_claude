<?xml version="1.0" encoding="UTF-8"?>

<!--
  Navigation Main Behavior Tree
  ==============================
  Autonomous navigation using A* (A-Star) pathfinding.

  Open in Groot2: File → Load Tree → Select this file

  Algorithm: A* (A-Star) — Hart, Nilsson & Raphael (1968)
    f(n) = g(n) + h(n), Octile heuristic, O(E log V)
-->

<root BTCPP_format="4" main_tree_to_execute="NavigationMain">

  <BehaviorTree ID="NavigationMain">

    <!-- Retry until agent reaches the target -->
    <RetryUntilSuccessful num_attempts="-1">

      <Sequence name="MainSequence">

        <!-- 1. Update position from sensors -->
        <UpdateAgentPosition name="UpdateSensors"/>

        <!-- 2. Make sure we have a target -->
        <HasTarget name="CheckTarget"/>

        <!-- 3. Do one navigation step this tick -->
        <Fallback name="EnsurePathAndMove">

          <!-- CASE A: Already have a path? → walk one step -->
          <Sequence name="MoveAlongPath">
            <HasPath name="HasRemainingPath"/>

            <!-- Move or handle obstacle -->
            <Fallback name="MoveOrWait">

              <!-- A1: Obstacle nearby? → wait (with backoff) -->
              <Sequence name="AvoidObstacle">
                <IsObstacleNearby name="DetectObstacle" scan_radius="1"/>
                <WaitAtObstacle name="BackoffWait" wait_max="2"/>
              </Sequence>

              <!-- A2: Path ahead blocked? → recompute -->
              <Sequence name="ReplanIfBlocked">
                <IsPathBlocked name="CheckPathBlocked"/>
                <RecomputePath name="RecomputeBlockedPath"/>
              </Sequence>

              <!-- A3: Normal step forward -->
              <MoveToNextWaypoint name="StepForward" speed="1.0"/>

            </Fallback>
          </Sequence>

          <!-- CASE B: No path → compute one with A* -->
          <ComputePath name="ComputeAStarPath" algorithm="astar"/>

        </Fallback>

        <!-- 4. Arrived at target? -->
        <IsTargetReached name="VerifyArrival" reach_threshold="1.0"/>

      </Sequence>

    </RetryUntilSuccessful>

  </BehaviorTree>

  <!-- ============================================================ -->
  <!-- Node Models (for Groot meta-info)                            -->
  <!-- ============================================================ -->
  <TreeNodesModel>
    <Action ID="ComputePath" editable="true">
      <input_port name="algorithm"/>
    </Action>
    <Condition ID="HasPath" editable="true"/>
    <Condition ID="HasTarget" editable="true"/>
    <Condition ID="IsObstacleNearby" editable="true">
      <input_port name="scan_radius"/>
    </Condition>
    <Condition ID="IsPathBlocked" editable="true"/>
    <Condition ID="IsTargetReached" editable="true">
      <input_port name="reach_threshold"/>
    </Condition>
    <Action ID="MoveToNextWaypoint" editable="true">
      <input_port name="speed"/>
    </Action>
    <Action ID="MoveToTarget" editable="true"/>
    <Action ID="RecomputePath" editable="true"/>
    <Action ID="RotateTowardTarget" editable="true"/>
    <Action ID="UpdateAgentPosition" editable="true"/>
    <Action ID="WaitAtObstacle" editable="true">
      <input_port name="wait_max"/>
    </Action>
  </TreeNodesModel>

</root>
