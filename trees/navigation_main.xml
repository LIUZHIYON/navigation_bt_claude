<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="NavigationMain">
  <BehaviorTree ID="FollowPath">
    <ReactiveSequence name="FollowPathLoop">
      <HasPath name="HasRemainingPath"/>
      <Inverter name="PathClear">
        <IsPathBlocked name="CheckNextBlocked"/>
      </Inverter>
      <Fallback name="MoveOrHandleObstacle">
        <Sequence name="HandleObstacle">
          <IsObstacleNearby name="ObstacleDetected"
                            scan_radius="1"/>
          <WaitAtObstacle name="BackoffWait"
                          wait_max="5"/>
          <RecomputePath name="RecomputeAfterWait"/>
        </Sequence>
        <Sequence name="NormalMovement">
          <MoveToNextWaypoint name="StepToWaypoint"
                              speed="1.0"/>
        </Sequence>
        <MoveToTarget name="DirectMoveFallback"/>
      </Fallback>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="NavigationMain">
    <RetryUntilSuccessful num_attempts="-1">
      <ReactiveSequence name="MainSequence">
        <UpdateAgentPosition name="UpdateSensors"/>
        <HasTarget name="CheckTarget"/>
        <Sequence name="NavigateToTarget">
          <ComputePath name="ComputeAStarPath"
                       algorithm="astar"/>
          <SubTree ID="FollowPath"/>
          <IsTargetReached name="VerifyArrival"
                           reach_threshold="1.5"/>
        </Sequence>
      </ReactiveSequence>
    </RetryUntilSuccessful>
  </BehaviorTree>

  <BehaviorTree ID="ObstacleAvoidance">
    <ReactiveSequence name="ObstacleHandling">
      <HasPath name="HasWaypoints"/>
      <Fallback name="MoveSafely">
        <KeepRunningUntilFailure>
          <Sequence name="AvoidIfNeeded">
            <IsObstacleNearby name="ScanForObstacles"
                              scan_radius="2"/>
            <Fallback name="AvoidanceStrategy">
              <Sequence name="RotateAndMove">
                <RotateTowardTarget name="FaceTarget"/>
                <Inverter name="ForwardClear">
                  <IsPathBlocked name="CheckForwardBlocked"/>
                </Inverter>
                <MoveToNextWaypoint name="MoveAfterRotate"
                                    speed=""/>
              </Sequence>
              <Sequence name="ReplanPath">
                <RecomputePath name="AStarReplan"/>
              </Sequence>
              <WaitAtObstacle name="ExponentialBackoff"
                              wait_max="5"/>
            </Fallback>
          </Sequence>
        </KeepRunningUntilFailure>
        <Sequence name="NormalStep">
          <Inverter name="IsClear">
            <IsPathBlocked name="CheckClear"/>
          </Inverter>
          <MoveToNextWaypoint name="StepForward"
                              speed="1.0"/>
        </Sequence>
      </Fallback>
    </ReactiveSequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ComputePath"
            editable="true">
      <input_port name="algorithm"/>
    </Action>
    <Condition ID="HasPath"
               editable="true"/>
    <Condition ID="HasTarget"
               editable="true"/>
    <Condition ID="IsObstacleNearby"
               editable="true">
      <input_port name="scan_radius"/>
    </Condition>
    <Condition ID="IsPathBlocked"
               editable="true"/>
    <Condition ID="IsTargetReached"
               editable="true">
      <input_port name="reach_threshold"/>
    </Condition>
    <Action ID="MoveToNextWaypoint"
            editable="true">
      <input_port name="speed"/>
    </Action>
    <Action ID="MoveToTarget"
            editable="true"/>
    <Action ID="RecomputePath"
            editable="true"/>
    <Action ID="RotateTowardTarget"
            editable="true"/>
    <Action ID="UpdateAgentPosition"
            editable="true"/>
    <Action ID="WaitAtObstacle"
            editable="true">
      <input_port name="wait_max"/>
    </Action>
  </TreeNodesModel>

</root>
