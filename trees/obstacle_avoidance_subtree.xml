<?xml version="1.0" encoding="UTF-8"?>

<!--
  Obstacle Avoidance Subtree
  ===========================
  Reusable subtree for reactive obstacle avoidance during navigation.

  Embed in other trees with:
    <SubTree ID="ObstacleAvoidance"/>

  Strategy:
    1. Scan surroundings for obstacles
    2. If obstacle detected within scan radius:
       a. Rotate to find a clear direction
       b. If rotation fails, recompute the A* path
       c. As last resort, wait (exponential backoff)
    3. If no obstacle, proceed with normal movement
-->

<root BTCPP_format="4">

  <BehaviorTree ID="ObstacleAvoidance">

    <ReactiveSequence name="ObstacleHandling">

      <HasPath name="HasWaypoints"/>

      <Fallback name="MoveSafely">

        <!-- Priority 1: Obstacle avoidance loop -->
        <KeepRunningUntilFailure>
          <Sequence name="AvoidIfNeeded">

            <!-- Scan for obstacles within 2 cells -->
            <IsObstacleNearby name="ScanForObstacles" scan_radius="2"/>

            <!-- Obstacle detected — choose avoidance strategy -->
            <Fallback name="AvoidanceStrategy">

              <!-- Strategy A: Rotate and check if forward is clear -->
              <Sequence name="RotateAndCheck">
                <RotateTowardTarget name="OrientToTarget"/>

                <!-- Is forward clear? Invert the "blocked" check -->
                <Inverter name="ForwardIsClear">
                  <IsPathBlocked name="StillBlocked"/>
                </Inverter>

                <MoveToNextWaypoint name="MoveAfterRotate"/>
              </Sequence>

              <!-- Strategy B: Dynamic A* replanning -->
              <Sequence name="ReplanPath">
                <RecomputePath name="AStarReplan"/>
              </Sequence>

              <!-- Strategy C: Wait with exponential backoff -->
              <WaitAtObstacle name="ExponentialBackoff" wait_max="5"/>

            </Fallback>

          </Sequence>
        </KeepRunningUntilFailure>

        <!-- Priority 2: Normal step-by-step movement (path clear) -->
        <Sequence name="NormalStep">
          <Inverter name="ClearCheck">
            <IsPathBlocked name="CheckClear"/>
          </Inverter>
          <MoveToNextWaypoint name="StepForward" speed="1.0"/>
        </Sequence>

      </Fallback>

    </ReactiveSequence>

  </BehaviorTree>

</root>
