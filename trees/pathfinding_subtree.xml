<?xml version="1.0" encoding="UTF-8"?>

<!--
  Pathfinding Subtree
  ====================
  Reusable subtree for A* path computation.

  Embed in other trees with:
    <SubTree ID="Pathfinding"/>

  Encapsulates:
    1. Verify target is set
    2. Run A* pathfinding algorithm
    3. Validate the computed path

  Algorithm: A* (A-Star) — Hart, Nilsson & Raphael (1968)
    f(n) = g(n) + h(n)
    Heuristic: Octile distance
-->

<root BTCPP_format="4">

  <BehaviorTree ID="Pathfinding">

    <Sequence name="ComputePathSequence">

      <!-- Verify we have a target destination -->
      <HasTarget name="CheckTargetExists"/>

      <!-- Run the A* pathfinding algorithm -->
      <ComputePath name="RunAStar" algorithm="astar"/>

      <!-- Validate we got a valid path -->
      <HasPath name="ValidatePath"/>

    </Sequence>

  </BehaviorTree>

</root>
